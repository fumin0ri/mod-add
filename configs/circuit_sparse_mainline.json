  "minimum_alive_per_row": 4,
  "activation_keep_fraction": 0.25,
  "activation_sparsity_locations": "attn_in,attn_q,attn_k,attn_v,attn_out,mlp_in,mlp_neuron,mlp_out,resid_post_attn,resid_post_mlp",
  "lr_warmup_frac": 0.01,
  "lr_decay": true,
  "grad_clip_rms": 1.0
