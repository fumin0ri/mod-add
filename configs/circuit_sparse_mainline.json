{
  "seed": 0,
  "modulus": 113,
  "train_fraction": 0.3,
  "d_model": 2048,
  "n_heads": 128,
  "d_head": 16,
  "d_mlp": 8192,
  "n_layers": 8,
  "learning_rate": 0.001,
  "weight_decay": 0.1,
  "adam_beta1": 0.9,
  "adam_beta2": 0.95,
  "adam_eps": 0.1,
  "epochs": 40000,
  "log_every": 100,
  "checkpoint_every": 1000,
  "out_dir": "runs/circuit_sparse_mainline",
